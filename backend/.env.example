# ─── Server ───────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/crime_reporting

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── KYC Provider (Dojah-compatible) ─────────────────────
DOJAH_BASE_URL=https://api.dojah.io
DOJAH_VERIFICATION_ENDPOINT=/api/v1/kyc/verify
DOJAH_APP_ID=replace_with_dojah_app_id
DOJAH_API_KEY=replace_with_dojah_api_key
DOJAH_TIMEOUT_MS=10000

# ─── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY=replace_with_a_long_random_secret

# ─── Client ───────────────────────────────────────────────
CLIENT_URL=http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176
RESET_PASSWORD_URL=http://localhost:5175/reset-password

# ─── AI Moderation ────────────────────────────────────────
AI_MODERATION_PROVIDER=heuristic
AI_MODERATION_TIMEOUT_MS=5000
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODERATION_MODEL=gpt-4.1-mini

# ─── Law Enforcement Integration ─────────────────────────
LAW_ENFORCEMENT_ENDPOINT=https://agency.example.com/api/cases/upsert
LAW_ENFORCEMENT_API_KEY=replace_with_remote_api_key
LAW_ENFORCEMENT_SIGNING_SECRET=replace_with_hmac_secret
LAW_ENFORCEMENT_TIMEOUT_MS=8000
INTEGRATION_WEBHOOK_KEY=replace_with_inbound_webhook_key

# ─── Geo / Nearby authority detection (optional) ─────────────────────────
GOOGLE_MAPS_API_KEY=replace_me_optional

# ─── Optional notifications ─────────────────────────────
FCM_SERVICE_ACCOUNT=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# ─── Premium Plan (Manual Transfer Verification) ─────────────────────────
PREMIUM_PLAN_PRICE_NGN=5000
PREMIUM_BANK_ACCOUNT_NAME=VOV Crime Premium
PREMIUM_BANK_ACCOUNT_NUMBER=0000000000
PREMIUM_BANK_NAME=Your Bank Name
PREMIUM_STREAM_CODE=2026

# ─── Streaming Scalability (WebRTC / Hybrid SFU / HLS) ──────────────────
# STREAMING_MODE: webrtc | hybrid | hls
STREAMING_MODE=webrtc

# Adaptive quality defaults
ADAPTIVE_QUALITY_ENABLED=true
MOBILE_QUALITY_DEFAULT=low
DESKTOP_QUALITY_DEFAULT=auto

# SFU provider (for hybrid mode)
SFU_URL=
SFU_API_KEY=
SFU_API_SECRET=

# HLS provider (for hls mode)
HLS_INGEST_URL=
HLS_PLAYBACK_BASE_URL=
HLS_SIGNING_KEY=
