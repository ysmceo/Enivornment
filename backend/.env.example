# ─── Server ───────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/crime_reporting

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY=replace_with_a_long_random_secret

# ─── Client ───────────────────────────────────────────────
CLIENT_URL=http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176

# ─── AI Moderation ────────────────────────────────────────
AI_MODERATION_PROVIDER=heuristic
AI_MODERATION_TIMEOUT_MS=5000
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODERATION_MODEL=gpt-4.1-mini

# ─── Law Enforcement Integration ─────────────────────────
LAW_ENFORCEMENT_ENDPOINT=https://agency.example.com/api/cases/upsert
LAW_ENFORCEMENT_API_KEY=replace_with_remote_api_key
LAW_ENFORCEMENT_SIGNING_SECRET=replace_with_hmac_secret
LAW_ENFORCEMENT_TIMEOUT_MS=8000
INTEGRATION_WEBHOOK_KEY=replace_with_inbound_webhook_key

# ─── Geo / Nearby authority detection (optional) ─────────────────────────
GOOGLE_MAPS_API_KEY=replace_me_optional

# ─── Optional notifications ─────────────────────────────
FCM_SERVICE_ACCOUNT=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
